    ingest/
      fetcher.py             # HTTP client with retries, ETag/If-Modified-Since
      parser.py              # parse raw → intermediate item
      normalizer.py          # map to Article schema; timezone & date filters
      dedupe.py              # URL canonicalization + hash
      enricher.py            # NER/rules to tag teams/players; match players.csv
