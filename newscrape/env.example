# Sports News Scraper Configuration

# Application Environment
APP_ENV=dev
APP_TZ=America/New_York

# HTTP Client Configuration
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_BASE=0.5
USER_AGENT=sports-news-scraper/0.1 (+contact:magnus@example.com)

# Database Configuration
DB_URL=sqlite:///./news.db

# API Keys (optional)
GUARDIAN_API_KEY=
SCRAPINGBEE_API_KEY=

# Rate Limiting
DEFAULT_RATE_LIMIT_PER_SECOND=1

# Player Matching
PLAYER_MATCH_THRESHOLD=0.7
ENABLE_NER=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

